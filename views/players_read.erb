<h1>tournament</h1>

<h2>
  Tournament <%= @tournament.id %>
</h2>

<p>
  <%= erb :links, :locals => {:tournament => @tournament} %>
</p>

start: <%= @tournament.start %> <br />
duration: <%= @tournament.duration %> <br />
courts: <%= @tournament.courts %> <br />

<p>
  teams:
  <ul>
    <% @tournament.teams.each do |team| %>
      <li>
        <%= team.name %>
        <ul>
          <% team.players.each do |player| %>
            <li><%= player %></li>
          <% end %>
        </ul>
      </li>
    <% end %>
  </ul>
</p>

